includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app/
        - database/factories/
        - database/seeders/
        - tests/

    level: 6

    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        - identifier: missingType.generics
